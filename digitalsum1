      {"id":43,"q":"Manufacturer 15%, wholesaler 10%, retailer 20%. Retail price 1518. Manufacturing cost?","options":["Rs. 1000","Rs. 1200","Rs. 1250","Rs. 1500"],"ans":0},
      {"id":44,"q":"Single equivalent discount for 20% and 15% successive?","options":["30%","32%","35%","38%"],"ans":1},
      {"id":45,"q":"Marked 40% above CP, discount 25%. Gain/Loss %?","options":["5% Gain","5% Loss","10% Gain","15% Gain"],"ans":0},
      {"id":46,"q":"Marked 800, sold 576 after two discounts. First 10%, second?","options":["15%","18%","20%","25%"],"ans":2},
      {"id":47,"q":"Discount 15% on MP, profit 19%. CP:MP ratio?","options":["3:5","4:7","5:7","6:7"],"ans":2},
      {"id":48,"q":"Buys 5 for Rs.4, sells 4 for Rs.5. Profit %?","options":["45%","50%","56.25%","60%"],"ans":2},
      {"id":49,"q":"Buys 11 for 10 and 9 for 10, sells 10 for 10. Overall?","options":["1% Gain","1% Loss","2% Gain","2% Loss"],"ans":1},
      {"id":50,"q":"Dishonest uses 900g instead of 1kg. True gain %?","options":["10%","11.11%","12.5%","15%"],"ans":1}
    ],
    "negativeMarks": 0.25,
    "totalTime": 3600,
    "totalQuestions": 50
  };

  // ---------- APP STATE ----------
  let state = {
    current: 0,
    answers: {},
    marked: new Set(),
    visited: new Set(),
    submitted: false,
    timer: EXAM_CONFIG.totalTime,
    lang: 'en', // 'en' or 'hi'
    dark: false,
    candidate: '',
    shuffledIndices: []
  };

  function shuffleArray(arr) {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function loadState() {
    try {
      const saved = localStorage.getItem('thp_cbt_state_v2');
      if (saved) {
        const parsed = JSON.parse(saved);
        Object.assign(state, parsed);
        state.marked = new Set(parsed.marked || []);
        state.visited = new Set(parsed.visited || []);
        state.answers = parsed.answers || {};
        if (!state.shuffledIndices || state.shuffledIndices.length !== EXAM_CONFIG.totalQuestions) {
          state.shuffledIndices = shuffleArray([...Array(EXAM_CONFIG.totalQuestions).keys()]);
        }
        return true;
      }
    } catch(e) {}
    return false;
  }

  function saveState() {
    const toStore = {
      current: state.current,
      answers: state.answers,
      marked: [...state.marked],
      visited: [...state.visited],
      timer: state.timer,
      candidate: state.candidate,
      shuffledIndices: state.shuffledIndices,
      lang: state.lang,
      dark: state.dark
    };
    localStorage.setItem('thp_cbt_state_v2', JSON.stringify(toStore));
  }

  function getQuestion(index) {
    const idx = state.shuffledIndices[index];
    return EXAM_CONFIG.questions[idx];
  }

  // ---------- LANGUAGE TOGGLE ----------
  function setLanguage(lang) {
    state.lang = lang;
    document.body.classList.remove('lang-en', 'lang-hi');
    document.body.classList.add('lang-' + lang);
    // Update dynamic elements that depend on language
    document.getElementById('totalQDisplay').textContent = EXAM_CONFIG.totalQuestions;
    document.getElementById('totalQDisplayHi').textContent = EXAM_CONFIG.totalQuestions;
    document.getElementById('totalQDisplay2').textContent = EXAM_CONFIG.totalQuestions;
    document.getElementById('totalQDisplay3').textContent = EXAM_CONFIG.totalQuestions;
    saveState();
  }

  function toggleLanguage() {
    const newLang = state.lang === 'en' ? 'hi' : 'en';
    setLanguage(newLang);
    // Re-render question to update any language-dependent text (though questions are math)
    if (!state.submitted && document.getElementById('examPage').classList.contains('hidden') === false) {
      renderQuestion();
    }
  }

  // ---------- THEME TOGGLE ----------
  function toggleTheme() {
    state.dark = !state.dark;
    document.getElementById('appBody').classList.toggle('dark-mode', state.dark);
    saveState();
  }

  // ---------- UI RENDER ----------
  function renderQuestion() {
    const q = getQuestion(state.current);
    if (!q) return;
    document.getElementById('qNumDisplay').textContent = state.current+1;
    document.getElementById('questionText').innerHTML = q.q;
    const container = document.getElementById('optionsContainer');
    container.innerHTML = '';
    const selected = state.answers[q.id] !== undefined ? state.answers[q.id] : -1;
    q.options.forEach((opt, idx) => {
      const div = document.createElement('div');
      div.className = 'flex items-start gap-2';
      const radio = document.createElement('input');
      radio.type = 'radio';
      radio.name = 'questionOption';
      radio.value = idx;
      radio.id = `opt_${idx}`;
      radio.className = 'mt-1';
      if (selected === idx) radio.checked = true;
      radio.onchange = () => {
        state.answers[q.id] = idx;
        state.visited.add(q.id);
        saveState();
        updatePalette();
        updateProgress();
      };
      const label = document.createElement('label');
      label.htmlFor = `opt_${idx}`;
      label.className = 'option-label flex-1 text-sm md:text-base';
      label.innerHTML = opt;
      div.appendChild(radio);
      div.appendChild(label);
      container.appendChild(div);
    });
    const badge = document.getElementById('qStatusBadge');
    if (state.marked.has(q.id)) badge.innerHTML = '<span class="en-text">🔖 Marked</span><span class="hi-text hidden">🔖 चिह्नित</span>';
    else if (state.answers[q.id] !== undefined) badge.innerHTML = '<span class="en-text">✔ Answered</span><span class="hi-text hidden">✔ उत्तर दिया</span>';
    else badge.innerHTML = '<span class="en-text">Not answered</span><span class="hi-text hidden">अनुत्तरित</span>';
    document.querySelectorAll('.palette-btn').forEach(btn => btn.classList.remove('current'));
    const currBtn = document.querySelector(`.palette-btn[data-index="${state.current}"]`);
    if (currBtn) currBtn.classList.add('current');
    MathJax.typesetPromise().catch(()=>{});
  }

  function buildPalette() {
    const grid = document.getElementById('paletteGrid');
    grid.innerHTML = '';
    for (let i = 0; i < EXAM_CONFIG.totalQuestions; i++) {
      const btn = document.createElement('button');
      btn.className = 'palette-btn not-answered';
      btn.dataset.index = i;
      btn.textContent = i+1;
      btn.onclick = () => { state.current = i; renderQuestion(); saveState(); };
      grid.appendChild(btn);
    }
    updatePalette();
  }

  function updatePalette() {
    const btns = document.querySelectorAll('.palette-btn');
    btns.forEach((btn, idx) => {
      const q = getQuestion(idx);
      btn.classList.remove('answered', 'marked', 'not-answered');
      if (state.marked.has(q.id)) btn.classList.add('marked');
      else if (state.answers[q.id] !== undefined) btn.classList.add('answered');
      else btn.classList.add('not-answered');
    });
    document.querySelectorAll('.palette-btn').forEach(b => b.classList.remove('current'));
    const curr = document.querySelector(`.palette-btn[data-index="${state.current}"]`);
    if (curr) curr.classList.add('current');
  }

  function updateProgress() {
    const total = EXAM_CONFIG.totalQuestions;
    const done = Object.keys(state.answers).filter(id => state.answers[id] !== undefined).length;
    const pct = (done / total) * 100;
    document.getElementById('progressBar').style.width = pct + '%';
    document.getElementById('answeredCount').textContent = done;
  }

  // ---------- EXAM ACTIONS ----------
  function saveAndNext() {
    const q = getQuestion(state.current);
    const radios = document.querySelectorAll('input[name="questionOption"]');
    let selected = -1;
    radios.forEach(r => { if (r.checked) selected = parseInt(r.value); });
    if (selected !== -1) {
      state.answers[q.id] = selected;
      state.visited.add(q.id);
      saveState();
    }
    nextQuestion();
  }

  function markForReview() {
    const q = getQuestion(state.current);
    if (state.marked.has(q.id)) state.marked.delete(q.id);
    else state.marked.add(q.id);
    saveState();
    renderQuestion();
    updatePalette();
  }

  function clearResponse() {
    const q = getQuestion(state.current);
    delete state.answers[q.id];
    saveState();
    renderQuestion();
    updatePalette();
    updateProgress();
  }

  function previousQuestion() {
    if (state.current > 0) { state.current--; renderQuestion(); saveState(); }
  }

  function nextQuestion() {
    if (state.current < EXAM_CONFIG.totalQuestions - 1) { state.current++; renderQuestion(); saveState(); }
  }

  // ---------- TIMER ----------
  let timerInterval = null;
  function startTimer() {
    if (timerInterval) clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      state.timer--;
      if (state.timer <= 0) {
        clearInterval(timerInterval);
        submitExam();
      }
      updateTimerDisplay();
      saveState();
    }, 1000);
  }

  function updateTimerDisplay() {
    const mins = Math.floor(state.timer / 60);
    const secs = state.timer % 60;
    document.getElementById('timerDisplay').innerHTML = `<i class="far fa-clock mr-1"></i> ${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}`;
  }

  // ---------- SUBMIT & FIREBASE ----------
  async function submitExam() {
    if (state.submitted) return;
    if (!confirm('Submit the exam? Answers will be final.')) return;
    state.submitted = true;
    clearInterval(timerInterval);
    document.getElementById('examPage').classList.add('hidden');
    document.getElementById('resultPage').classList.remove('hidden');
    showResult();
    saveState();

    try {
      const db = window.db;
      const ref = window.refDb;
      const push = window.pushRef;
      const timestamp = window.serverTimestamp;
      const name = state.candidate || 'Anonymous';
      const score = parseFloat(document.getElementById('resScore').textContent);
      const correct = parseInt(document.getElementById('resCorrect').textContent);
      const wrong = parseInt(document.getElementById('resWrong').textContent);
      const skipped = parseInt(document.getElementById('resSkipped').textContent);
      await push(ref(db, 'cbt_results'), {
        candidateName: name,
        score, correct, wrong, skipped,
        totalQuestions: EXAM_CONFIG.totalQuestions,
        answers: state.answers,
        timestamp: timestamp()
      });
      console.log('Result saved to Firebase');
    } catch(e) {
      console.error('Firebase save error:', e);
    }
  }

  // ---------- RESULT ----------
  function showResult() {
    let correct = 0, wrong = 0, skipped = 0;
    const details = [];
    EXAM_CONFIG.questions.forEach((q) => {
      const userAns = state.answers[q.id];
      const correctAns = q.ans;
      let status = '';
      if (userAns === undefined) { skipped++; status = 'Skipped'; }
      else if (userAns === correctAns) { correct++; status = 'Correct'; }
      else { wrong++; status = 'Wrong'; }
      details.push({ id: q.id, question: q.q, user: userAns!==undefined?q.options[userAns]:'—', correct: q.options[correctAns], status });
    });
    const score = correct - (wrong * 0.25);
    document.getElementById('resScore').textContent = score.toFixed(2);
    document.getElementById('resCorrect').textContent = correct;
    document.getElementById('resWrong').textContent = wrong;
    document.getElementById('resSkipped').textContent = skipped;
    const reviewDiv = document.getElementById('resultReview');
    reviewDiv.innerHTML = details.map(d => 
      `<div class="border-b border-gray-200 dark:border-gray-600 py-2 flex flex-wrap gap-2"><span class="font-medium">Q${d.id}</span> <span class="text-gray-600 dark:text-gray-400">${d.question.substring(0,80)}...</span> <span class="ml-auto ${d.status==='Correct'?'text-green-600':d.status==='Wrong'?'text-red-600':'text-gray-400'}">${d.status} (Your: ${d.user})</span></div>`
    ).join('');
  }

  // ---------- EXPORT ----------
  function exportPDF() { alert('PDF export (simulated) – use browser print or library.'); }
  function exportExcel() { alert('Excel export (simulated) – CSV available instead.'); }
  function exportCSV() {
    let csv = "QID,Question,Your Answer,Correct,Status\n";
    EXAM_CONFIG.questions.forEach(q => {
      const u = state.answers[q.id]!==undefined?q.options[state.answers[q.id]]:'—';
      const c = q.options[q.ans];
      const s = state.answers[q.id]===undefined?'Skipped':(state.answers[q.id]===q.ans?'Correct':'Wrong');
      csv += `${q.id},"${q.q.replace(/,/g,'')}",${u},${c},${s}\n`;
    });
    const blob = new Blob([csv], {type:'text/csv'});
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = 'THP_Result.csv';
    link.click();
  }

  // ---------- NAVIGATION ----------
  function startExam() {
    const name = document.getElementById('candidateName').value.trim() || 'Candidate';
    state.candidate = name;
    document.getElementById('candidateNameDisplay').textContent = name;
    document.getElementById('loginPage').classList.add('hidden');
    document.getElementById('instructionsPage').classList.remove('hidden');
    document.getElementById('totalQDisplay').textContent = EXAM_CONFIG.totalQuestions;
    document.getElementById('totalQDisplayHi').textContent = EXAM_CONFIG.totalQuestions;
    document.getElementById('totalQDisplay3').textContent = EXAM_CONFIG.totalQuestions;
  }

  function beginExam() {
    document.getElementById('instructionsPage').classList.add('hidden');
    document.getElementById('examPage').classList.remove('hidden');
    if (!state.shuffledIndices || state.shuffledIndices.length !== EXAM_CONFIG.totalQuestions) {
      state.shuffledIndices = shuffleArray([...Array(EXAM_CONFIG.totalQuestions).keys()]);
    }
    buildPalette();
    renderQuestion();
    updateProgress();
    updateTimerDisplay();
    startTimer();
    saveState();
    document.addEventListener('contextmenu', e => e.preventDefault());
    document.addEventListener('copy', e => e.preventDefault());
    document.addEventListener('paste', e => e.preventDefault());
    document.addEventListener('selectstart', e => e.preventDefault());
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && !state.submitted) {
        alert('⚠️ Tab switch detected. Stay on exam page.');
      }
    });
  }

  function goToLogin() {
    if (!state.submitted && confirm('Going back will lose progress?')) {
      localStorage.removeItem('thp_cbt_state_v2');
      location.reload();
    } else if (state.submitted) {
      location.reload();
    }
  }

  // ---------- INIT ----------
  (function init() {
    const loaded = loadState();
    // Apply language & theme
    setLanguage(state.lang || 'en');
    document.getElementById('appBody').classList.toggle('dark-mode', state.dark);
    if (loaded && state.candidate && !state.submitted) {
      document.getElementById('loginPage').classList.add('hidden');
      document.getElementById('examPage').classList.remove('hidden');
      document.getElementById('candidateNameDisplay').textContent = state.candidate;
      buildPalette();
      renderQuestion();
      updateProgress();
      updateTimerDisplay();
      startTimer();
    } else if (loaded && state.submitted) {
      document.getElementById('loginPage').classList.add('hidden');
      document.getElementById('resultPage').classList.remove('hidden');
      showResult();
    } else {
      state.shuffledIndices = shuffleArray([...Array(EXAM_CONFIG.totalQuestions).keys()]);
      saveState();
    }
  })();
</script>
