    body { font-family: 'Segoe UI', Roboto, system-ui, sans-serif; background: #f0f4ff; transition: background 0.3s, color 0.3s; }
    .cbt-card { background: white; border-radius: 1.2rem; box-shadow: 0 8px 30px rgba(0,20,80,0.08); transition: background 0.3s, border-color 0.3s; }
    .palette-btn { width: 2.6rem; height: 2.6rem; border-radius: 50%; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; border: 1px solid #d0d9e8; background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .palette-btn.answered { background: #1a56db; color: white; border-color: #1a56db; }
    .palette-btn.marked { background: #f59e0b; color: white; border-color: #f59e0b; }
    .palette-btn.not-answered { background: white; color: #1e293b; }
    .palette-btn.current { outline: 3px solid #2563eb; outline-offset: 2px; }
    .option-label { display: block; padding: 0.75rem 1rem; border-radius: 0.75rem; border: 1px solid #e2e8f0; margin-bottom: 0.5rem; cursor: pointer; transition: 0.15s; background: #fafcff; font-weight: 500; }
    .option-label:hover { background: #eef2ff; border-color: #94a3b8; }
    input[type="radio"]:checked + .option-label { background: #dbeafe; border-color: #2563eb; font-weight: 600; }
    .dark-mode { background: #0b1120; color: #e2e8f0; }
    .dark-mode .cbt-card { background: #1e293b; color: #e2e8f0; border-color: #334155; }
    .dark-mode .option-label { background: #1e293b; border-color: #475569; color: #e2e8f0; }
    .dark-mode input[type="radio"]:checked + .option-label { background: #1e3a5f; border-color: #3b82f6; }
    .dark-mode .palette-btn { background: #1e293b; color: #cbd5e1; border-color: #475569; }
    .dark-mode .palette-btn.answered { background: #2563eb; color: white; }
    .dark-mode .palette-btn.marked { background: #d97706; color: white; }
    .dark-mode .palette-btn.current { outline-color: #60a5fa; }
    .bg-govt-blue { background: #0a2a66; }
    .text-govt-gold { color: #f5b342; }
    .lang-hi .en-text { display: none; }
    .lang-hi .hi-text { display: inline; }
    .lang-en .hi-text { display: none; }
    .lang-en .en-text { display: inline; }
    button:active { transform: scale(0.96); }
  </style>
</head>
